# SilentWatch environment example
# Copy to .env.local for development.

# --- Application ---
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=SilentWatch
NEXT_PUBLIC_APP_ENV=development

# --- Map tiles ---
# Default uses MapLibre demo tiles. For production, point at a self-hosted
# tile server or commercial provider that you have lawful rights to use.
NEXT_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json

# --- Backend integration (mocked by default) ---
# When unset, the app serves data from in-memory mock adapters under /api/*.
# Set to point at a real FastAPI/NestJS backend when one exists.
# BACKEND_URL=http://api:8000

# --- Database (placeholder for future real backend) ---
# POSTGRES_HOST=db
# POSTGRES_PORT=5432
# POSTGRES_USER=silentwatch
# POSTGRES_PASSWORD=changeme
# POSTGRES_DB=silentwatch

# --- Object storage (placeholder) ---
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=silentwatch-evidence
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# --- Auth (placeholder) ---
# AUTH_SECRET=replace-me
# AUTH_SESSION_TTL=86400

# --- Feature flags (all OFF by default; lawful integrations only) ---
FEATURE_CAMERA_INTEGRATION=false
FEATURE_NETWORK_INVENTORY=false
FEATURE_ENV_SENSORS=false
FEATURE_WEATHER_OVERLAY=false
